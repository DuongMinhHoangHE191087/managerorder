{
  "name": "managerorder",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @managerorder/admin-web dev",
    "dev:admin": "pnpm --filter @managerorder/admin-web dev",
    "start": "pnpm --dir apps/admin-web run start",
    "lint:admin": "pnpm --dir apps/admin-web run lint",
    "typecheck:admin": "pnpm --dir apps/admin-web run typecheck",
    "test:admin": "pnpm --dir apps/admin-web run test",
    "build:admin": "pnpm --dir apps/admin-web run build",
    "build": "pnpm build:admin",
    "lint": "pnpm lint:admin",
    "typecheck": "pnpm typecheck:admin",
    "test": "pnpm test:admin",
    "check:bots": "pnpm --dir apps/admin-web run check:telegram-runtime",
    "check:bots:live": "pnpm --dir apps/admin-web run check:bots:live",
    "seed:bots:live": "pnpm --dir apps/admin-web run seed:bots:live",
    "cleanup:bots:live": "pnpm --dir apps/admin-web run cleanup:bots:live",
    "check:runtime": "pwsh -NoProfile -File ./scripts/run-runtime-qa.ps1",
    "check:all": "node ./scripts/check-all-project.mjs",
    "check:all:live-telegram": "node ./scripts/check-all-project.mjs --live-telegram",
    "audit:prod": "pnpm audit --prod",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build:admin"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "turbo": "^2.5.8"
  },
  "pnpm": {
    "overrides": {
      "next": "^16.2.4",
      "eslint-config-next": "^16.2.4",
      "zod-validation-error": "^4.0.2",
      "postcss": "^8.5.10",
      "uuid": "^14.0.0",
      "axios": "^1.15.0",
      "follow-redirects": "^1.15.12",
      "dompurify": "^3.3.4"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ],
      "allowAny": [
        "react",
        "react-dom"
      ]
    }
  },
  "dependencies": {
    "next": "^16.2.4"
  }
}
