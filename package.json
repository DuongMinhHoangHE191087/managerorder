{
  "name": "managerorder",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "corepack pnpm --filter @managerorder/admin-web dev",
    "dev:admin": "corepack pnpm --filter @managerorder/admin-web dev",
    "dev:bot": "corepack pnpm --filter @managerorder/zalo-bot-js start:bot",
    "start": "corepack pnpm --dir apps/admin-web run start",
    "lint:admin": "corepack pnpm --dir apps/admin-web run lint",
    "lint:bot": "corepack pnpm --dir packages/zalo-bot-js run lint",
    "typecheck:admin": "corepack pnpm --dir apps/admin-web run typecheck",
    "typecheck:bot": "corepack pnpm --dir packages/zalo-bot-js run typecheck",
    "test:admin": "corepack pnpm --dir apps/admin-web run test",
    "test:bot": "corepack pnpm --dir packages/zalo-bot-js run test",
    "build:admin": "corepack pnpm --dir apps/admin-web run build",
    "build:bot": "corepack pnpm --dir packages/zalo-bot-js run build",
    "build:all": "corepack pnpm build:admin && corepack pnpm build:bot",
    "build:full": "corepack pnpm build:all",
    "lint": "corepack pnpm lint:admin && corepack pnpm lint:bot",
    "typecheck": "corepack pnpm typecheck:admin && corepack pnpm typecheck:bot",
    "test": "corepack pnpm test:admin && corepack pnpm test:bot",
    "build": "corepack pnpm build:admin",
    "check:bots": "corepack pnpm --dir apps/admin-web run check:telegram-runtime && corepack pnpm --dir apps/admin-web run check:zalo-runtime",
    "check:bots:live": "corepack pnpm --dir apps/admin-web run check:bots:live",
    "seed:bots:live": "corepack pnpm --dir apps/admin-web run seed:bots:live",
    "cleanup:bots:live": "corepack pnpm --dir apps/admin-web run cleanup:bots:live",
    "check:runtime": "pwsh -NoProfile -File ./scripts/run-runtime-qa.ps1",
    "check:all": "node ./scripts/check-all-project.mjs",
    "check:all:live-telegram": "node ./scripts/check-all-project.mjs --live-telegram",
    "audit:prod": "corepack pnpm audit --prod",
    "check": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm build:all"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "turbo": "^2.5.8"
  },
  "pnpm": {
    "overrides": {
      "next": "^16.2.4",
      "eslint-config-next": "^16.2.4",
      "zod-validation-error": "^4.0.2",
      "postcss": "^8.5.10",
      "uuid": "^14.0.0",
      "axios": "^1.15.0",
      "follow-redirects": "^1.15.12",
      "dompurify": "^3.3.4"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ],
      "allowAny": [
        "react",
        "react-dom"
      ]
    }
  },
  "dependencies": {
    "next": "^16.2.4"
  }
}
