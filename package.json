{
  "name": "managerorder",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=22 <25",
    "pnpm": ">=9 <11"
  },
  "scripts": {
    "dev": "corepack pnpm --filter @managerorder/admin-web dev",
    "dev:admin": "corepack pnpm --filter @managerorder/admin-web dev",
    "dev:bot": "corepack pnpm --filter @managerorder/zalo-bot-js start:bot",
    "lint:admin": "corepack pnpm --dir apps/admin-web run lint",
    "lint:bot": "corepack pnpm --dir packages/zalo-bot-js run lint",
    "typecheck:admin": "corepack pnpm --dir apps/admin-web run typecheck",
    "typecheck:bot": "corepack pnpm --dir packages/zalo-bot-js run typecheck",
    "test:admin": "corepack pnpm --dir apps/admin-web run test",
    "test:bot": "corepack pnpm --dir packages/zalo-bot-js run test",
    "build:admin": "corepack pnpm --dir apps/admin-web run build",
    "build:bot": "corepack pnpm --dir packages/zalo-bot-js run build",
    "lint": "corepack pnpm lint:admin && corepack pnpm lint:bot",
    "typecheck": "corepack pnpm typecheck:admin && corepack pnpm typecheck:bot",
    "test": "corepack pnpm test:admin && corepack pnpm test:bot",
    "build": "corepack pnpm build:admin && corepack pnpm build:bot",
    "audit:prod": "corepack pnpm audit --prod",
    "check": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm build"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "turbo": "^2.5.8"
  },
  "pnpm": {
    "overrides": {
      "next": "^16.2.3",
      "eslint-config-next": "^16.2.3",
      "axios": "^1.15.0",
      "follow-redirects": "^1.15.12",
      "dompurify": "^3.3.4"
    }
  }
}
