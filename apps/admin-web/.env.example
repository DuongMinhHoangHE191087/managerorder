# ManagerOrder admin web environment sample.
# Copy this file to apps/admin-web/.env.local for local dev/start.
# Do not commit real secrets in .env.local.
#
# Generate 64-hex encryption keys:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# =============================================================================
# Core runtime
# =============================================================================
NODE_ENV=development
APP_NAME=ManagerOrder
NEXT_PUBLIC_APP_NAME=ManagerOrder
NEXT_TURBO=true
BUILD_STANDALONE=false

# Public site URLs. Use your production HTTPS domain on deploy.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
SITE_URL=http://localhost:3000
RUNTIME_BASE_URL=http://localhost:3000
BASE_URL=http://localhost:3000

# =============================================================================
# Supabase
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# Aliases used by scripts/examples. Keep them aligned with the values above.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=replace_with_supabase_anon_or_service_key
SUPABASE_SERVICE_KEY=replace_with_supabase_service_role_key
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Tenant/account defaults used by scripts, bots and test helpers.
ACCOUNT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_TEST_ACCOUNT_ID=00000000-0000-0000-0000-000000000000
TEST_ACCOUNT_ID=00000000-0000-0000-0000-000000000000
E2E_MOCK_ACCOUNT_ID=

# =============================================================================
# Auth and admin access
# =============================================================================
JWT_SECRET=replace_with_long_random_jwt_secret
JWT_ACCESS_TOKEN_EXPIRY=24h
JWT_REFRESH_TOKEN_EXPIRY=7d

# Optional one-time admin registration/access key.
ADMIN_SECRET_KEY=
USER_ACCESS_TOKEN=

# =============================================================================
# Credential/account sharing security
# =============================================================================
# Required for source account passwords, 2FA secrets and backup codes.
CREDENTIAL_ENCRYPTION_KEY=replace_with_64_hex_chars

# Required for /share unlock cookies.
SHARE_UNLOCK_SECRET=replace_with_long_random_share_unlock_secret

# Required for premium account password encryption.
PREMIUM_PASSWORD_ENCRYPTION_KEY=replace_with_64_hex_chars

# Legacy fallback for premium encryption. Prefer PREMIUM_PASSWORD_ENCRYPTION_KEY.
ENCRYPTION_KEY=

# =============================================================================
# Short links
# =============================================================================
SHORT_LINK_RELAY_SECRET=replace_with_long_random_short_link_relay_secret
SHORT_LINK_PUBLIC_LANDING_ENABLED=true
SHORT_LINK_FORCE_DIRECT_REDIRECT=false
SHORT_LINK_SMOKE_ALLOW_DEGRADED=false

# =============================================================================
# Cron and internal jobs
# =============================================================================
CRON_SECRET=replace_with_long_random_cron_secret

# =============================================================================
# Telegram bot/runtime
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_ACCOUNT_ID=00000000-0000-0000-0000-000000000000
TELEGRAM_RUNTIME_MODE=polling
TELEGRAM_AUTO_REGISTER_WEBHOOK=false
TELEGRAM_WEBHOOK_SECRET=

# =============================================================================
# Zalo bot/OA/ZNS
# =============================================================================
ZALO_BOT_TOKEN=
ZALO_BOT_ACCOUNT_ID=00000000-0000-0000-0000-000000000000
ZALO_BOT_LANG=vi
ZALO_RUNTIME_MODE=disabled
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_TOKEN=
ZALO_OA_REFRESH_TOKEN=
ZALO_WEBHOOK_URL=
ZALO_WEBHOOK_SECRET=
ADMIN_ZALO_USER_IDS=
ZNS_TEMPLATE_WELCOME=
ZNS_TEMPLATE_EXPIRY_REMINDER=
ZNS_TEMPLATE_EXPIRED=

# Optional Zalo test assets.
ZALO_TEST_PHOTO_CAPTION=
ZALO_TEST_PHOTO_URL_1=
ZALO_TEST_PHOTO_URL_2=
ZALO_TEST_PHOTO_URL_3=

# =============================================================================
# Google OAuth / Google Calendar
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Cloudinary upload integration
# =============================================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================================================
# AI integrations
# =============================================================================
GEMINI_API_KEY=
GEMINI_API_TOKEN=
GEMINI_MODEL=

# =============================================================================
# Redis/rate limiting
# =============================================================================
REDIS_URL=

# =============================================================================
# Realtime and feature flags
# =============================================================================
NEXT_PUBLIC_ENABLE_REALTIME_SUBSCRIPTIONS=false
ENABLE_DEPRECATED_MIGRATE_ROUTE=false

# Local fallback/debug flags. Keep false/empty in production.
CODEX_DEBUG_API_ERRORS=0
CODEX_USE_LOCAL_FALLBACK=0
CODEX_DISABLE_LOCAL_FALLBACK=1
CODEX_ALLOW_LOCAL_WEBHOOK_READ_FALLBACK=0

# =============================================================================
# E2E, QA and smoke test flags
# =============================================================================
CI=false
E2E_MOCK_SESSION=0
E2E_ALLOW_LOCAL_MOCK_FALLBACK=1
PLAYWRIGHT_SKIP_WEBSERVER=false
REQUIRE_PREMIUM_SEEDED_MODALS=false
CHECK_ALL_LIVE_TELEGRAM=0
CHECK_ALL_REUSE_RUNTIME=1
SMOKE_TARGET_TIMEOUT_MS=30000

# =============================================================================
# Example package/test-only variables
# =============================================================================
API_PORT=3001
OA_ACCESS_TOKEN=
