{
  "name": "@managerorder/admin-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "22.x",
    "pnpm": ">=9 <11"
  },
  "scripts": {
    "dev": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs ./scripts/runtime-supervisor.ts --mode=dev",
    "check:client-boundaries": "node ./scripts/check-client-boundaries.mjs",
    "check:css-tokens": "node ./scripts/check-css-tokens.mjs",
    "check:legacy-imports": "node ./scripts/check-legacy-imports.mjs",
    "check:short-link-schema": "node ./scripts/check-short-link-delivery-schema.mjs",
    "check:ui-copy": "node ./scripts/check-ui-copy-vi.mjs",
    "check:quality-guards": "node ./scripts/check-legacy-imports.mjs && node ./scripts/check-client-boundaries.mjs && node ./scripts/check-css-tokens.mjs && node ./scripts/check-ui-copy-vi.mjs",
    "pretypecheck": "node ./scripts/check-legacy-imports.mjs && node ./scripts/check-client-boundaries.mjs && node ./scripts/check-css-tokens.mjs && node ./scripts/check-ui-copy-vi.mjs",
    "pretest": "node ./scripts/check-legacy-imports.mjs && node ./scripts/check-client-boundaries.mjs && node ./scripts/check-css-tokens.mjs && node ./scripts/check-ui-copy-vi.mjs",
    "prebuild": "node ./scripts/check-legacy-imports.mjs && node ./scripts/check-client-boundaries.mjs && node ./scripts/check-css-tokens.mjs && node ./scripts/check-ui-copy-vi.mjs",
    "build": "node --max-old-space-size=4096 ../../node_modules/next/dist/bin/next build",
    "analyze:build": "node ./scripts/analyze-next-build.mjs",
    "build:ci": "next build",
    "check:telegram-runtime": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs ./scripts/check-telegram-runtime.ts",
    "check:bots:live": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs ./scripts/check-bots-live.ts",
    "seed:bots:live": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs ./scripts/bot-live-fixtures.ts",
    "cleanup:bots:live": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs ./scripts/cleanup-bot-live-fixtures.ts",
    "db:apply-short-link-migration": "node ./scripts/apply-short-link-delivery-migration.mjs",
    "check:zalo-runtime": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs ./scripts/check-zalo-runtime.ts",
    "start": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs ./scripts/runtime-supervisor.ts --mode=start",
    "lint": "eslint",
    "qa:visual": "node ./scripts/visual-qa.mjs",
    "qa:ops-runtime": "node ./scripts/visual-qa-short-links-calendar-bot.mjs",
    "smoke:short-links": "node ./scripts/short-link-public-smoke.mjs",
    "smoke:runtime": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs ./scripts/runtime-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node ./scripts/vitest-runner.mjs run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/business-smoke.spec.ts --project=chromium",
    "test:watch": "node ./scripts/vitest-runner.mjs",
    "test:coverage": "node ./scripts/vitest-runner.mjs run --coverage",
    "telegram:poll": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs ./scripts/telegram-bot-poll.ts",
    "zalo:poll": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs ./scripts/zalo-bot-poll.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-table": "^8.21.3",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.35.0",
    "googleapis": "171.4.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "next-auth": "^4.24.13",
    "nextjs-toploader": "^3.9.17",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.7.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "swagger-ui-react": "^5.32.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/forms": "^0.5.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "xlsx": "^0.18.5"
  }
}
