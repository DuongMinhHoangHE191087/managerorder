# Zalo bot package sample.
ZALO_BOT_TOKEN=your_zalo_bot_token_here
ZALO_BOT_ACCOUNT_ID=your_account_uuid
ZALO_BOT_LANG=vi
ZALO_RUNTIME_MODE=polling

# Zalo OA OAuth2 for ZNS and token refresh.
ZALO_APP_ID=your_app_id
ZALO_APP_SECRET=your_app_secret
ZALO_OA_TOKEN=your_oa_access_token
ZALO_OA_REFRESH_TOKEN=your_oa_refresh_token
ZALO_WEBHOOK_URL=
ZALO_WEBHOOK_SECRET=

# Gemini AI.
GEMINI_API_KEY=
GEMINI_API_TOKEN=
GEMINI_MODEL=

# Supabase.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key
SUPABASE_SERVICE_KEY=
ACCOUNT_ID=your_account_uuid

# Admin Zalo user IDs, comma-separated.
ADMIN_ZALO_USER_IDS=zalo_id_1,zalo_id_2

# ZNS template IDs from Zalo Business Dashboard.
ZNS_TEMPLATE_WELCOME=
ZNS_TEMPLATE_EXPIRY_REMINDER=
ZNS_TEMPLATE_EXPIRED=

# Optional local tests.
API_PORT=3001
OA_ACCESS_TOKEN=
USER_ACCESS_TOKEN=
ZALO_TEST_PHOTO_CAPTION=
ZALO_TEST_PHOTO_URL_1=
ZALO_TEST_PHOTO_URL_2=
ZALO_TEST_PHOTO_URL_3=
